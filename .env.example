SPRING_PROFILES_ACTIVE=product
SERVER_PORT=8080

DB_URL=jdbc:postgresql://postgres:5432/fatihozkurtcom
DB_USERNAME=postgres
DB_PASSWORD=postgres

REDIS_HOST=redis
REDIS_PORT=6379

JWT_ISSUER=fatihozkurtcom
JWT_SECRET=replace-with-a-strong-secret
JWT_ACCESS_EXP_MIN=15
JWT_REFRESH_EXP_DAYS=14

APP_DEFAULT_LOCALE=tr
APP_LOCALE_HEADER=X-Locale
APP_CORS_ALLOWED_ORIGINS=https://fatihozkurt.com
APP_REQUIRE_HTTPS=true
APP_COOKIE_SECURE=true
APP_COOKIE_SAMESITE=Strict
APP_REFRESH_COOKIE_NAME=refresh_token

RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SEC=600
RATE_LIMIT_FORGOT_MAX=3
RATE_LIMIT_FORGOT_WINDOW_SEC=1800
RATE_LIMIT_CONTACT_MAX=5
RATE_LIMIT_CONTACT_WINDOW_SEC=600

ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_EMAIL=

APP_MAIL_FROM=noreply@fatihozkurt.com
APP_MAIL_PROVIDER=log
APP_STORAGE_ENABLED=true
APP_STORAGE_ENDPOINT=http://minio:9000
APP_STORAGE_ACCESS_KEY=minioadmin
APP_STORAGE_SECRET_KEY=minioadmin
APP_STORAGE_REGION=us-east-1
APP_STORAGE_BUCKET_PUBLIC=public-assets
APP_STORAGE_BUCKET_PROJECT=project-assets
APP_STORAGE_BUCKET_RESUME=resume-assets

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
